{
  "type": "object",
  "required": ["collection", "vector"],
  "properties": {
    "collection": {
      "type": "string",
      "minLength": 1
    },
    "vector": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 1
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "default": 10
    },
    "filter": {
      "type": "object",
      "additionalProperties": true,
      "description": "Provider-native filter expression (passed through as-is)"
    },
    "with_payload": {
      "type": "boolean",
      "default": true
    },
    "score_threshold": {
      "type": "number",
      "description": "Minimum score; results below threshold are dropped"
    }
  },
  "additionalProperties": false
}
