# Zentro Forge environment example
# Copy values into your shell environment (backend) and frontend/.env.local (frontend).

# -----------------------------------------------------------------------------
# Backend: Core
# -----------------------------------------------------------------------------
AGENT_COMPILER_APP_NAME=Zentro Forge API
AGENT_COMPILER_DEBUG=false
AGENT_COMPILER_DATABASE_URL=sqlite+aiosqlite:///./agent_compiler.db
AGENT_COMPILER_DEFAULT_ENGINE=langchain
AGENT_COMPILER_DEFAULT_MODEL=gpt-4o-mini
AGENT_COMPILER_ABSTAIN_THRESHOLD=0.3

# -----------------------------------------------------------------------------
# Backend: Security/Auth
# -----------------------------------------------------------------------------
AGENT_COMPILER_API_KEY=
AGENT_COMPILER_API_KEY_HEADER=X-API-Key
AGENT_COMPILER_REQUIRE_AUTH_FOR_READS=false
AGENT_COMPILER_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
AGENT_COMPILER_CORS_ALLOW_CREDENTIALS=true
AGENT_COMPILER_CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
AGENT_COMPILER_CORS_ALLOW_HEADERS=*

# Optional encryption key for credentials and secret env vars
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORGE_MASTER_KEY=

# -----------------------------------------------------------------------------
# Backend: Export and runtime policies
# -----------------------------------------------------------------------------
AGENT_COMPILER_EXPORT_TEMP_DIR=
AGENT_COMPILER_EXPORT_TTL_HOURS=24
AGENT_COMPILER_ENFORCE_V1_TOOL_ALLOWLIST=true
AGENT_COMPILER_V1_TOOL_ALLOWLIST=search,calculator,datetime,web_search,url_reader,mcp:*

# -----------------------------------------------------------------------------
# Backend: MCP
# PRODUCTION WARNING: enabling MCP allows subprocess execution.
#   - MCP_ALLOWED_COMMANDS: comma-separated list of allowed executables (empty = any).
#     Recommended for production: restrict to the exact commands your MCP servers need
#     (e.g. npx,node for npm-based MCP servers; python for Python-based ones).
#   - MCP_ALLOWED_TOOLS: comma-separated list of allowed tool names (empty = any).
#     Restrict to the specific tool names exposed by your MCP servers.
# -----------------------------------------------------------------------------
AGENT_COMPILER_MCP_ENABLED=false
AGENT_COMPILER_MCP_TIMEOUT_SECONDS=20
# Recommended production example (restrict to what you actually use):
# AGENT_COMPILER_MCP_ALLOWED_COMMANDS=npx,node
AGENT_COMPILER_MCP_ALLOWED_COMMANDS=
# AGENT_COMPILER_MCP_ALLOWED_TOOLS=pubmed_search,arxiv_search
AGENT_COMPILER_MCP_ALLOWED_TOOLS=
AGENT_COMPILER_MCP_MAX_RESPONSE_CHARS=20000

# -----------------------------------------------------------------------------
# Backend: Observability
# -----------------------------------------------------------------------------
AGENT_COMPILER_LOG_LEVEL=INFO
AGENT_COMPILER_JSON_LOGS=false
AGENT_COMPILER_OTEL_ENABLED=false
AGENT_COMPILER_OTEL_SERVICE_NAME=agent-compiler
AGENT_COMPILER_OTEL_ENDPOINT=

# -----------------------------------------------------------------------------
# Provider credentials (backend process env)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Frontend (put this in frontend/.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
