* text=auto

# Enforce LF for source/config/docs to avoid CRLF/LF drift across OS.
*.py text eol=lf
*.pyi text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.env text eol=lf
*.sh text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Windows-native scripts can keep CRLF for better local UX.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets: never modify line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text eol=lf
*.zip binary
*.pdf binary
